# ─────────────────────────────────────────────────────────────
#  CLERK AUTHENTICATION
#  1. Go to https://dashboard.clerk.com and create an app
#  2. Copy your keys and paste them in .env.local (NOT here)
# ─────────────────────────────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY_HERE

# ─────────────────────────────────────────────────────────────
#  FIREBASE (optional — leave blank to rely on Clerk only)
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# API URL (Vite dev-proxy handles this — leave blank in dev)
VITE_API_URL=

# ─────────────────────────────────────────────────────────────
#  SERVER (set these in server/.env)
# ─────────────────────────────────────────────────────────────
PORT=5000
GEMINI_API_KEY=your_gemini_api_key_here

# Email alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MaaRaksha <alerts@maaraksha.in>
ALERT_EMAIL=alerts@phc.gov.in
FAMILY_ALERT_EMAIL=family@demo.com
